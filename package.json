{
  "name": "dor101-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Dorchester 101 - Desktop Application",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "next dev",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "next build",
    "build:electron": "npm run build && electron-builder",
    "build:electron:win": "npm run build && electron-builder --win --publish=never",
    "build:electron:win:publish": "npm run build && electron-builder --win --publish=always",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@types/leaflet": "^1.9.21",
    "axios": "^1.17.0",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "17.3.1",
    "drizzle-orm": "0.45.2",
    "framer-motion": "^12.40.0",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "next": "16.2.5",
    "pg": "8.20.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-i18next": "^17.0.8",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "rss-parser": "^3.13.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.6.0",
    "xml2js": "^0.6.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.17",
    "@types/node": "22.19.15",
    "@types/pg": "8.18.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "concurrently": "^8.2.2",
    "drizzle-kit": "0.31.10",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.0",
    "postcss": "8.5.8",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.dorchester101.app",
    "productName": "Dorchester 101",
    "files": [
      "out/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "certificateFile": null,
      "certificatePassword": null,
      "signingHashAlgorithms": [
        "sha256"
      ],
      "sign": "./scripts/sign.js"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Dorchester 101"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "Nikoxkx",
      "repo": "Dorchester-101"
    }
  }
}
